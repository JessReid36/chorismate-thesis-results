#!/bin/bash
#PBS -N cm10c_prod
#PBS -l select=1:ncpus=8:ngpus=1:mem=16gb
#PBS -l walltime=168:00:00
#PBS -m ae
#PBS -M 18660916@sun.ac.za
#PBS -j oe
#PBS -o /home/18660916/system_development/04_amber_md/10c_production/10c_prod.pbs.out

set -uo pipefail
echo "host=$(hostname)  jobid=${PBS_JOBID:-UNSET}  start=$(date)"
nvidia-smi -L 2>/dev/null || { echo "FAIL no GPU visible"; exit 1; }

# choose a scratch dir with >= 25 GB free (trajectory is ~13 GB); fail fast if none
need_kb=26214400
scratch=""
for base in /scratch-small-local /scratch-large-network; do
  d="$base/${PBS_JOBID}"
  mkdir -p "$d" 2>/dev/null || continue
  avail=$(df -Pk "$d" 2>/dev/null | awk 'END{print $4}')
  if [[ "${avail:-0}" -ge "$need_kb" ]]; then scratch="$d"; echo "scratch=$scratch (avail ${avail} KB)"; break; fi
  rmdir "$d" 2>/dev/null || true
done
[[ -n "$scratch" ]] || { echo "FAIL no scratch dir with >=25GB free for the trajectory"; exit 1; }
# clean our own scratch on ANY exit (normal end, qdel, or walltime kill)
trap 'cd "/home/18660916/system_development/04_amber_md/10c_production" 2>/dev/null; rm -rf "$scratch" 2>/dev/null' EXIT TERM

cp "/home/18660916/system_development/04_amber_md/10c_production/prod.in" "/home/18660916/system_development/03_amber/tleap_build/complex_solvated.prmtop" "/home/18660916/system_development/04_amber_md/10b_equil/npt5.rst7" "$scratch"/
cd "$scratch"

set +u
export PERL5LIB="${PERL5LIB:-}" PYTHONPATH="${PYTHONPATH:-}"
module load app/amber22/22
set -u
command -v pmemd.cuda >/dev/null || { echo "FAIL pmemd.cuda not found"; exit 1; }
[[ -e "/apps/mambaforge/pkgs/cudatoolkit-11.8.0-h37601d7_11/lib/libcufft.so.10" ]]   || { echo "FAIL CUDA libs missing at /apps/mambaforge/pkgs/cudatoolkit-11.8.0-h37601d7_11/lib"; exit 1; }
[[ -e "/apps/mambaforge/envs/medaka/lib/libopenblas.so.0" ]] || { echo "FAIL openblas missing at /apps/mambaforge/envs/medaka/lib"; exit 1; }
export LD_LIBRARY_PATH="/apps/mambaforge/pkgs/cudatoolkit-11.8.0-h37601d7_11/lib:/apps/mambaforge/envs/medaka/lib:${LD_LIBRARY_PATH:-}"

echo "=== running 20 ns production (pmemd.cuda) ==="
pmemd.cuda -O -i prod.in -o prod.out -p "complex_solvated.prmtop" -c "npt5.rst7" \
  -r prod.rst7 -x prod.nc -inf prod.mdinfo
rc=$?

echo "=== copying results to $HOME (1 TB tier) ==="
cp -f prod.out prod.mdinfo "/home/18660916/system_development/04_amber_md/10c_production"/ 2>/dev/null || true
if [[ $rc -eq 0 ]]; then
  cp -f prod.rst7 prod.nc "/home/18660916/system_development/04_amber_md/10c_production"/ 2>/dev/null || true
fi

[[ $rc -eq 0 ]] || { echo "FAIL pmemd.cuda rc=$rc"; tail -30 "/home/18660916/system_development/04_amber_md/10c_production/prod.out" 2>/dev/null; exit 1; }
[[ -s "/home/18660916/system_development/04_amber_md/10c_production/prod.nc" && -s "/home/18660916/system_development/04_amber_md/10c_production/prod.rst7" ]] || { echo "FAIL missing trajectory or restart"; exit 1; }
echo "=== summary ==="
grep -E "ns/day|TIME\(PS\) =|Density" "/home/18660916/system_development/04_amber_md/10c_production/prod.out" | tail -5 || true
ls -lh "/home/18660916/system_development/04_amber_md/10c_production/prod.nc" "/home/18660916/system_development/04_amber_md/10c_production/prod.rst7"
echo "end=$(date)"
echo "FINAL PASS: 10c production complete (trajectory prod.nc, restart prod.rst7)"
