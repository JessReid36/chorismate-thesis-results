NAME = job.inp
|  1> ! B3LYP D3BJ def2-SVP def2/J RIJCOSX CPCM TightSCF Opt
|  2> %maxcore 3000
|  3> %pal nprocs 8 end
|  4> %cpcm epsilon 4.0 end
|  5> %scf MaxIter 300 end
|  6> %geom
|  7>    coordsys cartesian
|  8>    Calc_Hess true
|  9>    Recalc_Hess 5
| 10>    MaxIter 60
| 11> end
| 12> %pointcharges "design.pc"
| 13> * xyzfile -2 1 start.xyz
| 14> 
| 15>                          ****END OF INPUT****
